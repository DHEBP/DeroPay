# DeroPay Gateway Server Configuration
# Copy to .env and fill in your values.

# --- Server ---
PORT=3080

# --- DERO RPC ---
# Point these at your DERO wallet and daemon.
# Self-hosted: localhost. Remote wallet: your wallet's IP/domain.
# NOTE: docker compose ignores these two and wires the in-network
# wallet:10103 / daemon:10102 services automatically.
DERO_WALLET_RPC_URL=http://127.0.0.1:10103/json_rpc
DERO_DAEMON_RPC_URL=http://127.0.0.1:10102/json_rpc

# RPC basic auth. REQUIRED by docker compose: the bundled wallet serves its
# RPC with --rpc-login using these credentials, and the gateway authenticates
# with them. Pick a strong password — this gates access to the wallet RPC.
DERO_RPC_USERNAME=deropay
DERO_RPC_PASSWORD=

# --- Bundled node & wallet (docker compose only) ---
# By default compose builds a self-hosted DERO daemon (--fastsync: a recent
# state snapshot, not the multi-week full replay) and auto-creates a merchant
# wallet on first run, writing its recovery seed to SEED-BACKUP.txt in the
# wallet volume. BACK THAT UP — the 25 words are your money.
#
# To use a REMOTE daemon instead of the bundled node, set this (host:port):
# DERO_DAEMON_ADDRESS=node.derofoundation.org:11012
#
# Optional at-rest encryption for the wallet file. If set, the auto-created
# wallet is encrypted with this password (and it's also used to open a wallet
# you mount yourself). Leave empty for an unencrypted file protected only by
# network isolation + --rpc-login. Keep it in sync with the wallet volume:
# changing it will not re-encrypt an existing wallet.
# WALLET_PASSWORD=

# --- API Keys ---
# Comma-separated list of valid API keys.
# Generate one with: bun run generate-key
# If empty, all routes are open (not recommended for production).
DEROPAY_API_KEY=

# --- Webhooks ---
# URL to POST payment events to (your store's webhook endpoint).
# DEROPAY_WEBHOOK_URL=https://mystore.com/webhooks/dero
# DEROPAY_WEBHOOK_SECRET=your-webhook-secret-here

# --- Storage ---
# "memory" for development, "sqlite" for production.
DEROPAY_STORE=memory
# DEROPAY_SQLITE_PATH=./data/deropay.db

# --- Escrow ---
# Set to "true" to enable escrow smart contract support.
DEROPAY_ENABLE_ESCROW=false
# DEROPAY_ESCROW_FEE_BPS=250
# Default escrow expiration in blocks (~2 days at ~18s/block). Must be >= 4000
# (the on-chain contract rejects a shorter Bind window).
# DEROPAY_ESCROW_BLOCK_EXPIRATION=9600

# --- Payment Router ---
# Set to "true" to enable payment router smart contract support.
# The router allows instant on-chain payment splitting (merchant + optional fee).
DEROPAY_ENABLE_ROUTER=false

# --- Tuning ---
# DEROPAY_DEFAULT_TTL=900
# DEROPAY_DEFAULT_CONFIRMATIONS=3
# DEROPAY_POLL_INTERVAL_MS=5000
# DEROPAY_CORS_ORIGIN=*
