{
  "name": "dero-pay",
  "version": "0.4.0",
  "description": "Payment processing SDK for DERO \u2014 Accept DERO payments with invoices, payment monitoring, webhooks, and a merchant dashboard.",
  "type": "module",
  "main": "./dist/core/index.js",
  "types": "./dist/core/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./rpc": {
      "types": "./dist/rpc/index.d.ts",
      "import": "./dist/rpc/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./bridge": {
      "types": "./dist/bridge/index.d.ts",
      "import": "./dist/bridge/index.js"
    },
    "./escrow": {
      "types": "./dist/escrow/index.d.ts",
      "import": "./dist/escrow/index.js"
    },
    "./router": {
      "types": "./dist/router/index.d.ts",
      "import": "./dist/router/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./gateway": {
      "types": "./dist/gateway/index.d.ts",
      "import": "./dist/gateway/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./next": {
      "types": "./dist/next/index.d.ts",
      "import": "./dist/next/index.js"
    },
    "./x402": {
      "types": "./dist/x402/index.d.ts",
      "import": "./dist/x402/index.js"
    },
    "./x402/types": {
      "types": "./dist/x402/types.d.ts",
      "import": "./dist/x402/types.js"
    },
    "./x402/server": {
      "types": "./dist/x402/server.d.ts",
      "import": "./dist/x402/server.js"
    },
    "./x402/client": {
      "types": "./dist/x402/client.d.ts",
      "import": "./dist/x402/client.js"
    },
    "./x402/next": {
      "types": "./dist/x402/next.d.ts",
      "import": "./dist/x402/next.js"
    },
    "./agent": {
      "types": "./dist/agent/index.d.ts",
      "import": "./dist/agent/index.js"
    }
  },
  "bin": {
    "deropay-bridge": "./dist/bridge/cli.js"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DHEBP/DeroPay.git",
    "directory": "packages/dero-pay"
  },
  "homepage": "https://github.com/DHEBP/DeroPay/tree/main/packages/dero-pay#readme",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:unit": "vitest run --exclude '**/*.integration.test.ts'",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:exports": "tsup && vitest run --config vitest.exports.config.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "dero",
    "payment",
    "gateway",
    "cryptocurrency",
    "privacy",
    "invoice",
    "merchant",
    "web3",
    "payment-processor"
  ],
  "author": "DHEBP",
  "license": "MIT",
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "better-sqlite3": "^11.0.0",
    "react": "^19.0.0",
    "next": "^15.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "better-sqlite3": ">=9.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "next": ">=14.0.0"
  },
  "peerDependenciesMeta": {
    "better-sqlite3": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "next": {
      "optional": true
    }
  }
}