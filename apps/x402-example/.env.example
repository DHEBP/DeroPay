# DERO RPC endpoints
DEROPAY_WALLET_RPC_URL=http://127.0.0.1:10103/json_rpc
DEROPAY_DAEMON_RPC_URL=http://127.0.0.1:10102/json_rpc

# Shared secret used by receipt issue/verify + x402 route guard
DEROPAY_RECEIPT_SECRET=replace_with_long_random_secret

# Optional: lock to testnet behavior in examples
# DEROPAY_CHAIN_ID=dero-mainnet

# Agent payer demo (scripts/agent-pay.ts). Must be a DIFFERENT wallet than
# DEROPAY_WALLET_RPC_URL — paying the merchant wallet from itself won't
# register as an incoming transfer.
# AGENT_WALLET_RPC_URL=http://127.0.0.1:10104/json_rpc
# RESOURCE_URL=http://localhost:3000/api/protected/report
