{
  "name": "deropay-gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Standalone DeroPay payment gateway server — accept DERO payments from any platform.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --dts --clean",
    "start": "node dist/index.js",
    "generate-key": "tsx src/generate-key.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "dero-pay": "workspace:*",
    "hono": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
