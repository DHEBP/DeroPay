# DeroPay Dashboard Configuration
# Copy to .env.local and update values

# DERO Wallet RPC (must have --rpc-server enabled)
WALLET_RPC_URL=http://127.0.0.1:10103/json_rpc
DAEMON_RPC_URL=http://127.0.0.1:10102/json_rpc

# Optional: RPC authentication
# RPC_USERNAME=
# RPC_PASSWORD=

# Optional: Webhook notifications
# WEBHOOK_URL=https://mystore.com/webhooks/dero
# WEBHOOK_SECRET=your-secret-here

# Invoice defaults
DEFAULT_TTL_SECONDS=900
DEFAULT_CONFIRMATIONS=3
POLL_INTERVAL_MS=5000
